{
  "name": "tower-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:api": "openapi-typescript http://localhost:8080/openapi.json -o src/api/schema.d.ts"
  },
  "dependencies": {
